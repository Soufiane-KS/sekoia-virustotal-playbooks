{
  "name": "VT Enrich IP",
  "description": "Extract the destination IP from alert events and enrich it with VirusTotal. Posts country/ASN context, malicious file hashes, and malicious URLs associated with the IP.",
  "uuid": "3f8a2b1c-7d4e-5f6a-8b9c-0d1e2f3a4b5c",
  "tags": null,
  "nodes": {
    "0": {
      "name": "Alert Created",
      "type": "trigger",
      "outputs": {
        "default": ["1"]
      },
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a",
      "trigger_uuid": "785583cf-4377-43ce-a5fb-f4572eb57456"
    },
    "1": {
      "name": "Store Alert UUID",
      "type": "operator",
      "subtype": "store",
      "outputs": {
        "default": ["2"]
      },
      "modifications": [
        {
          "key": "uuid",
          "type": "append",
          "value": "{{ node.0.alert_uuid }}"
        }
      ]
    },
    "2": {
      "name": "Get Alert",
      "type": "action",
      "outputs": {
        "default": ["3"]
      },
      "arguments": {
        "stix": true,
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}"
      },
      "action_uuid": "8d189665-5401-4098-8d60-944de9a6199a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "3": {
      "name": "Get Events",
      "type": "action",
      "outputs": {
        "default": ["4"]
      },
      "arguments": {
        "query": "alert_short_ids: \"{{ node.2['short_id'] }}\"",
        "latest_time": "{{ node.2['last_seen_at'] }}",
        "earliest_time": "{{ node.2['first_seen_at'] }}"
      },
      "action_uuid": "af0b4355-a428-43d6-991c-d5ff878e17d5",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "4": {
      "name": "Extract Destination IP",
      "type": "action",
      "outputs": {
        "default": ["5"]
      },
      "arguments": {
        "file": "{{ node.3['events'] }}",
        "to_file": false,
        "jsonpath": "$..['destination.ip']",
        "return_list": false
      },
      "action_uuid": "ecedfa52-7033-4ea8-9c3b-93ad34295f87",
      "module_uuid": "07cce76b-a319-40ee-a0cf-1ba433431e21"
    },
    "5": {
      "name": "Scan IP on VirusTotal",
      "type": "action",
      "icon": "data:image/svg+xml;base64,",
      "outputs": {
        "default": ["6", "7", "9"]
      },
      "arguments": {
        "ip": "{{ node.4['output'][0] }}"
      },
      "action_uuid": "fee286fa-415b-4f04-bf26-536e40b64859",
      "module_uuid": "d023af1d-25d8-465b-b85f-2ed48214d6a5"
    },
    "6": {
      "name": "Post IP Summary",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "IP Enrichment by VirusTotal",
        "content": "**VirusTotal report for IP {{ node.4['output'][0] }}**\n- Country: {{ node.5.country }}\n- ASN: {{ node.5.asn }}\n- Malicious files served from this IP: {{ node.5['detected_downloaded_samples'] | length }}\n- Malicious URLs hosted on this IP: {{ node.5['detected_urls'] | length }}\n\n[Direct link to VirusTotal](https://www.virustotal.com/gui/ip-address/{{ node.4['output'][0] }})"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "7": {
      "name": "Malicious Files?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{% if node.5['detected_downloaded_samples'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["8"],
        "else": []
      }
    },
    "8": {
      "name": "Post Malicious File Hashes",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "IP Enrichment by VirusTotal",
        "content": "Malicious file hashes served from {{ node.4['output'][0] }}:\n{{ node.5['detected_downloaded_samples'] | map(attribute='sha256') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "9": {
      "name": "Malicious URLs?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{% if node.5['detected_urls'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["10"],
        "else": []
      }
    },
    "10": {
      "name": "Post Malicious URLs",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "IP Enrichment by VirusTotal",
        "content": "Malicious URLs hosted on {{ node.4['output'][0] }}:\n{{ node.5['detected_urls'] | map(attribute='url') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    }
  }
}
