{
  "name": "VT Enrich IP",
  "description": "Extract the destination IP from alert events and enrich it with VirusTotal. Posts a detection score comment and a list of malicious vendors.",
  "uuid": "3f8a2b1c-7d4e-5f6a-8b9c-0d1e2f3a4b5c",
  "tags": null,
  "nodes": {
    "0": {
      "name": "Alert Created",
      "type": "trigger",
      "outputs": {
        "default": ["1"]
      },
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a",
      "trigger_uuid": "785583cf-4377-43ce-a5fb-f4572eb57456"
    },
    "1": {
      "name": "Store Alert UUID",
      "type": "operator",
      "subtype": "store",
      "outputs": {
        "default": ["2"]
      },
      "modifications": [
        {
          "key": "uuid",
          "type": "append",
          "value": "{{ node.0.alert_uuid }}"
        }
      ]
    },
    "2": {
      "name": "Get Alert",
      "type": "action",
      "outputs": {
        "default": ["3"]
      },
      "arguments": {
        "stix": true,
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}"
      },
      "action_uuid": "8d189665-5401-4098-8d60-944de9a6199a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "3": {
      "name": "Get Events",
      "type": "action",
      "outputs": {
        "default": ["4"]
      },
      "arguments": {
        "query": "alert_short_ids: \"{{ node.2['short_id'] }}\"",
        "latest_time": "{{ node.2['last_seen_at'] }}",
        "earliest_time": "{{ node.2['first_seen_at'] }}"
      },
      "action_uuid": "af0b4355-a428-43d6-991c-d5ff878e17d5",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "4": {
      "name": "Extract Destination IP",
      "type": "action",
      "outputs": {
        "default": ["5"]
      },
      "arguments": {
        "file": "{{ node.3['events'] }}",
        "to_file": false,
        "jsonpath": "$..['destination.ip']",
        "return_list": false
      },
      "action_uuid": "ecedfa52-7033-4ea8-9c3b-93ad34295f87",
      "module_uuid": "07cce76b-a319-40ee-a0cf-1ba433431e21"
    },
    "5": {
      "name": "Scan IP on VirusTotal",
      "type": "action",
      "outputs": {
        "unknown": [],
        "detected": ["6", "7"],
        "not detected": ["6", "7"]
      },
      "arguments": {
        "url": "{{ node.4['output'][0] }}"
      },
      "action_uuid": "b43a7897-b92c-4fe1-8a5c-be9e023c4f1c",
      "module_uuid": "d023af1d-25d8-465b-b85f-2ed48214d6a5"
    },
    "6": {
      "name": "Post IP Score Comment",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "IP Enrichment by VirusTotal",
        "content": "{{ node.5.positives }}/{{ node.5.total }} security vendors flagged the target IP ({{ node.4['output'][0] }}) as malicious. [Direct link to VirusTotal]({{ node.5.permalink }})"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "7": {
      "loop": ["8"],
      "name": "Foreach Vendor",
      "type": "operator",
      "subtype": "foreach",
      "items": "{{ node.5['scans'] | list }}",
      "outputs": {
        "default": ["9"]
      }
    },
    "8": {
      "name": "Store Malicious Vendor",
      "type": "operator",
      "subtype": "store",
      "outputs": {
        "default": []
      },
      "modifications": [
        {
          "key": "vendor",
          "type": "append",
          "value": "{% if node.5['scans'][node.7.default.value]['detected'] != False %} {{ node.7.default['value'] }} {% endif %}"
        }
      ]
    },
    "9": {
      "name": "Any Detections?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{{ node.5.positives }}",
          "name": "More than 0 detections",
          "right": "{{ 0 }}",
          "comparison": ">"
        }
      ],
      "outputs": {
        "More than 0 detections": ["10"],
        "else": []
      }
    },
    "10": {
      "name": "Post Malicious Vendors List",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "content": "{% if node.5.positives > 0 %}List of security vendors which detected this IP as malicious: {{ (store.vendor|reject('equalto', None)|reject('equalto', '')|join(', ')) }}{% endif %}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    }
  }
}
