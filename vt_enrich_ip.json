      "cases": [
        {
          "left": "{% if node.14['detected_urls'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["19"],
        "else": []
      }
    },
    "19": {
      "name": "Post Malicious URLs (Src)",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Source IP Enrichment by VirusTotal",
        "content": "Malicious URLs hosted on {{ node.12['output'][0] }}:\n{{ node.14['detected_urls'] | map(attribute='url') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    }
  }
}
