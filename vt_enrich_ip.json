{
  "name": "VT Enrich IP",
  "description": "Extract destination and source IPs from alert events, skip private IPs, and enrich public IPs with VirusTotal. Posts country/ASN context, malicious file hashes, and malicious URLs.",
  "uuid": "3f8a2b1c-7d4e-5f6a-8b9c-0d1e2f3a4b5c",
  "tags": null,
  "nodes": {
    "0": {
      "name": "Alert Created",
      "type": "trigger",
      "outputs": {
        "default": ["1"]
      },
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a",
      "trigger_uuid": "785583cf-4377-43ce-a5fb-f4572eb57456"
    },
    "1": {
      "name": "Store Alert UUID",
      "type": "operator",
      "subtype": "store",
      "outputs": {
        "default": ["2"]
      },
      "modifications": [
        {
          "key": "uuid",
          "type": "append",
          "value": "{{ node.0.alert_uuid }}"
        }
      ]
    },
    "2": {
      "name": "Get Alert",
      "type": "action",
      "outputs": {
        "default": ["3"]
      },
      "arguments": {
        "stix": true,
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}"
      },
      "action_uuid": "8d189665-5401-4098-8d60-944de9a6199a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "3": {
      "name": "Get Events",
      "type": "action",
      "outputs": {
        "default": ["4", "12"]
      },
      "arguments": {
        "query": "alert_short_ids: \"{{ node.2['short_id'] }}\"",
        "latest_time": "{{ node.2['last_seen_at'] }}",
        "earliest_time": "{{ node.2['first_seen_at'] }}"
      },
      "action_uuid": "af0b4355-a428-43d6-991c-d5ff878e17d5",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "4": {
      "name": "Extract Destination IP",
      "type": "action",
      "outputs": {
        "default": ["5"]
      },
      "arguments": {
        "file": "{{ node.3['events'] }}",
        "to_file": false,
        "jsonpath": "$..['destination.ip']",
        "return_list": false
      },
      "action_uuid": "ecedfa52-7033-4ea8-9c3b-93ad34295f87",
      "module_uuid": "07cce76b-a319-40ee-a0cf-1ba433431e21"
    },
    "5": {
      "name": "Is Destination IP Private?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{%if node.4['output'][0] | regex_match('^(10\\..*|172\\.(1[6-9]|2[0-9]|3[01])\\..*|192\\.168\\..*)$') %}true1{% endif %}",
          "name": "Private IP",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Private IP": [],
        "else": ["6"]
      }
    },
    "6": {
      "name": "Scan Destination IP on VirusTotal",
      "type": "action",
      "icon": "data:image/svg+xml;base64,",
      "outputs": {
        "default": ["7", "8", "10"]
      },
      "arguments": {
        "ip": "{{ node.4['output'][0] }}"
      },
      "action_uuid": "fee286fa-415b-4f04-bf26-536e40b64859",
      "module_uuid": "d023af1d-25d8-465b-b85f-2ed48214d6a5"
    },
    "7": {
      "name": "Post Destination IP Summary",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Destination IP Enrichment by VirusTotal",
        "content": "**VirusTotal report for Destination IP {{ node.4['output'][0] }}**\n- Country: {{ node.6.country }}\n- ASN: {{ node.6.asn }}\n- Malicious files served from this IP: {{ node.6['detected_downloaded_samples'] | length }}\n- Malicious URLs hosted on this IP: {{ node.6['detected_urls'] | length }}\n\n[Direct link to VirusTotal](https://www.virustotal.com/gui/ip-address/{{ node.4['output'][0] }})"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "8": {
      "name": "Malicious Files (Dest)?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{% if node.6['detected_downloaded_samples'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["9"],
        "else": []
      }
    },
    "9": {
      "name": "Post Malicious File Hashes (Dest)",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Destination IP Enrichment by VirusTotal",
        "content": "Malicious file hashes served from {{ node.4['output'][0] }}:\n{{ node.6['detected_downloaded_samples'] | map(attribute='sha256') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "10": {
      "name": "Malicious URLs (Dest)?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{% if node.6['detected_urls'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["11"],
        "else": []
      }
    },
    "11": {
      "name": "Post Malicious URLs (Dest)",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Destination IP Enrichment by VirusTotal",
        "content": "Malicious URLs hosted on {{ node.4['output'][0] }}:\n{{ node.6['detected_urls'] | map(attribute='url') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "12": {
      "name": "Extract Source IP",
      "type": "action",
      "outputs": {
        "default": ["13"]
      },
      "arguments": {
        "file": "{{ node.3['events'] }}",
        "to_file": false,
        "jsonpath": "$..['source.ip']",
        "return_list": false
      },
      "action_uuid": "ecedfa52-7033-4ea8-9c3b-93ad34295f87",
      "module_uuid": "07cce76b-a319-40ee-a0cf-1ba433431e21"
    },
    "13": {
      "name": "Is Source IP Private?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{%if node.12['output'][0] | regex_match('^(10\\..*|172\\.(1[6-9]|2[0-9]|3[01])\\..*|192\\.168\\..*)$') %}true1{% endif %}",
          "name": "Private IP",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Private IP": [],
        "else": ["14"]
      }
    },
    "14": {
      "name": "Scan Source IP on VirusTotal",
      "type": "action",
      "icon": "data:image/svg+xml;base64,",
      "outputs": {
        "default": ["15", "16", "18"]
      },
      "arguments": {
        "ip": "{{ node.12['output'][0] }}"
      },
      "action_uuid": "fee286fa-415b-4f04-bf26-536e40b64859",
      "module_uuid": "d023af1d-25d8-465b-b85f-2ed48214d6a5"
    },
    "15": {
      "name": "Post Source IP Summary",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Source IP Enrichment by VirusTotal",
        "content": "**VirusTotal report for Source IP {{ node.12['output'][0] }}**\n- Country: {{ node.14.country }}\n- ASN: {{ node.14.asn }}\n- Malicious files served from this IP: {{ node.14['detected_downloaded_samples'] | length }}\n- Malicious URLs hosted on this IP: {{ node.14['detected_urls'] | length }}\n\n[Direct link to VirusTotal](https://www.virustotal.com/gui/ip-address/{{ node.12['output'][0] }})"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "16": {
      "name": "Malicious Files (Src)?",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{% if node.14['detected_downloaded_samples'] | length > 0 %}true1{% endif %}",
          "name": "Yes",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Yes": ["17"],
        "else": []
      }
    },
    "17": {
      "name": "Post Malicious File Hashes (Src)",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "Source IP Enrichment by VirusTotal",
        "content": "Malicious file hashes served from {{ node.12['output'][0] }}:\n{{ node.14['detected_downloaded_samples'] | map(attribute='sha256') | join('\n') }}"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "18": {
      "name": "Malicious URLs (Src)?",
      "type": "operator",
