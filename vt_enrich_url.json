{
  "name": "VT Enrich URL",
  "description": "Extract the URL from alert STIX, validate its format, scan it on VirusTotal, and post the detection score as a comment.",
  "uuid": "b5e9f3a7-2c4d-8e1f-0a3b-5c7d9e1f2a3b",
  "tags": null,
  "nodes": {
    "0": {
      "name": "Alert Created",
      "type": "trigger",
      "outputs": {
        "default": ["1"]
      },
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a",
      "trigger_uuid": "785583cf-4377-43ce-a5fb-f4572eb57456"
    },
    "1": {
      "name": "Store Alert UUID",
      "type": "operator",
      "subtype": "store",
      "outputs": {
        "default": ["2"]
      },
      "modifications": [
        {
          "key": "uuid",
          "type": "append",
          "value": "{{ node.0.alert_uuid }}"
        }
      ]
    },
    "2": {
      "name": "Get Alert",
      "type": "action",
      "outputs": {
        "default": ["3"]
      },
      "arguments": {
        "stix": true,
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}"
      },
      "action_uuid": "8d189665-5401-4098-8d60-944de9a6199a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    },
    "3": {
      "name": "Extract URL from STIX",
      "type": "action",
      "outputs": {
        "default": ["4"]
      },
      "arguments": {
        "file": "{{ node.2.stix }}",
        "to_file": false,
        "jsonpath": "$.objects[?(type=\"observed-data\")].objects[?(@.type=\"url\")].value",
        "return_list": true
      },
      "action_uuid": "ecedfa52-7033-4ea8-9c3b-93ad34295f87",
      "module_uuid": "07cce76b-a319-40ee-a0cf-1ba433431e21"
    },
    "4": {
      "name": "Check URL Format",
      "type": "operator",
      "subtype": "condition",
      "cases": [
        {
          "left": "{%if node.3['output'][0] | regex_match('^http.*', ignore_case=False) %}true1{% endif %}",
          "name": "Starts with http",
          "right": "true1",
          "comparison": "=="
        }
      ],
      "outputs": {
        "Starts with http": ["5"],
        "else": []
      }
    },
    "5": {
      "name": "Scan URL on VirusTotal",
      "type": "action",
      "icon": "data:image/svg+xml;base64,",
      "outputs": {
        "unknown": [],
        "detected": ["6"],
        "not detected": ["6"]
      },
      "arguments": {
        "url": "{{ node.3['output'][0] }}"
      },
      "action_uuid": "b43a7897-b92c-4fe1-8a5c-be9e023c4f1c",
      "module_uuid": "d023af1d-25d8-465b-b85f-2ed48214d6a5"
    },
    "6": {
      "name": "Post URL Score Comment",
      "type": "action",
      "outputs": {
        "default": []
      },
      "arguments": {
        "uuid": "{{ (store.uuid | reject('equalto', None)) | join('') }}",
        "author": "URL VT score",
        "content": "{{ node.5.positives }}/{{ node.5.total }} security vendors flagged the target URL ({{ node.3['output'][0] }}) as malicious. [Direct link to VirusTotal]({{ node.5.permalink }})"
      },
      "action_uuid": "0d323de3-a864-4afe-a0c3-e7ff45883d7a",
      "module_uuid": "92d8bb47-7c51-445d-81de-ae04edbb6f0a"
    }
  }
}
